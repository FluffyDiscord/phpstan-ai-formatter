{
    "name": "webkult/phpstan-ai-formatter",
    "description": "Compact PHPStan error formatter designed for AI coding assistants. Transforms verbose PHPStan output into token-efficient format. Ideal for Claude, ChatGPT, Copilot and similar tools. Saves context window space while preserving all essential error information.",
    "type": "phpstan-extension",
    "license": "MIT",
    "keywords": [
        "phpstan",
        "phpstan-extension",
        "ai",
        "llm",
        "formatter",
        "claude",
        "chatgpt",
        "static-analysis"
    ],
    "authors": [
        {
            "name": "Benjamin Klein - webkult.de",
            "homepage": "https://webkult.de"
        }
    ],
    "require": {
        "php": "^7.4 || ^8.0",
        "phpstan/phpstan": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5 || ^10.0",
        "phpstan/phpstan-strict-rules": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Webkult\\PhpStanAiFormatter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webkult\\PhpStanAiFormatter\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "phpstan": {
            "includes": [
                "extension.neon"
            ]
        }
    }
}
